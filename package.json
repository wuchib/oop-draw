{
  "name": "oop-draw",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev:web": "pnpm --filter @oop-draw/editor-web dev",
    "dev:desktop": "pnpm --filter @oop-draw/editor-desktop dev",
    "build:web": "pnpm --filter @oop-draw/editor-web build",
    "build:desktop": "pnpm --filter @oop-draw/editor-desktop build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint . --ext .ts,.vue",
    "test": "vitest run",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --config commitlint.config.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.35.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.3.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^37.2.6",
    "electron-vite": "^4.0.0",
    "eslint": "^9.35.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.5.1",
    "jsdom": "^26.1.0",
    "pinia": "^3.0.3",
    "prettier": "^3.6.2",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vite": "^7.1.5",
    "vitest": "^3.2.4",
    "vue": "^3.5.21",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.0.6"
  },
  "dependencies": {
    "lucide-vue-next": "^0.577.0"
  }
}
